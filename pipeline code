# PIPELINE 5 — State-level revenue heatmap data
# ═══════════════════════════════════════════════════════════════════════════════
def pipeline_5_geo_revenue(db):
    print("=" * 60)
    print("PIPELINE 5 — Revenue by State (for Tableau map)")
    print("Business question: Which states have highest customer value?")
    print("=" * 60)

    pipeline = [
        {"$match": {"order_status": "delivered"}},
        {"$group": {
            "_id":          "$customer_state",
            "revenue":      {"$sum": "$total_amount"},
            "order_count":  {"$sum": 1},
            "unique_customers": {"$addToSet": "$customer_id"},
        }},
        {"$addFields": {
            "unique_customer_count": {"$size": "$unique_customers"},
        }},
        {"$sort": {"revenue": DESCENDING}},
        {"$project": {
            "_id":                  0,
            "state":                "$_id",
            "revenue":              {"$round": ["$revenue", 0]},
            "order_count":          1,
            "unique_customers":     "$unique_customer_count",
            "revenue_per_customer": {"$round": [
                {"$divide": ["$revenue", "$unique_customer_count"]}, 0
            ]},
        }},
    ]

    results = list(db.orders.aggregate(pipeline))

    print(f"\n{'State':<20} {'Revenue (₹)':>14} {'Orders':>8} {'Customers':>10} {'Rev/Customer':>13}")
    print("-" * 70)
    for r in results:
        print(f"{r['state']:<20} {r['revenue']:>14,.0f} {r['order_count']:>8,} {r['unique_customers']:>10,} {r['revenue_per_customer']:>13,.0f}")
    print(f"\n💡 Insight: Revenue/Customer reveals high-value markets beyond raw order volume.\n")
    return results


