# PIPELINE 1 — Revenue by category (with % share)
# ═══════════════════════════════════════════════════════════════════════════════
def pipeline_1_revenue_by_category(db):
    print("=" * 60)
    print("PIPELINE 1 — Revenue by Product Category")
    print("Business question: Which categories drive the most revenue?")
    print("=" * 60)

    pipeline = [
        # Step 1: Only look at delivered orders
        {"$match": {"order_status": "delivered"}},

        # Step 2: Unwind the items array — one doc per line item
        {"$unwind": "$items"},

        # Step 3: Group by category, sum revenue and count orders
        {"$group": {
            "_id":          "$items.category",
            "total_revenue": {"$sum": "$items.line_total"},
            "units_sold":   {"$sum": "$items.quantity"},
            "order_count":  {"$sum": 1},
        }},

        # Step 4: Sort by revenue descending
        {"$sort": {"total_revenue": DESCENDING}},

        # Step 5: Project clean field names + round revenue
        {"$project": {
            "_id":          0,
            "category":     "$_id",
            "revenue_inr":  {"$round": ["$total_revenue", 0]},
            "units_sold":   1,
            "order_count":  1,
            "avg_order_value": {"$round": [{"$divide": ["$total_revenue", "$order_count"]}, 0]},
        }},
    ]

    results = list(db.orders.aggregate(pipeline))
    total   = sum(r["revenue_inr"] for r in results)

    print(f"\n{'Category':<20} {'Revenue (₹)':>14} {'Share':>7} {'Units':>8} {'AOV (₹)':>10}")
    print("-" * 65)
    for r in results:
        share = r["revenue_inr"] / total * 100
        print(f"{r['category']:<20} {r['revenue_inr']:>14,.0f} {share:>6.1f}% {r['units_sold']:>8,} {r['avg_order_value']:>10,.0f}")
    print(f"\n{'TOTAL':<20} {total:>14,.0f}")
    print(f"\n💡 Insight: Top 2 categories likely account for 50%+ of revenue (Pareto effect).\n")
    return results


