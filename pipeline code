# PIPELINE 4 — Return rate by category
# ═══════════════════════════════════════════════════════════════════════════════
def pipeline_4_return_rates(db):
    print("=" * 60)
    print("PIPELINE 4 — Return Rate by Category")
    print("Business question: Which categories lose revenue to returns?")
    print("=" * 60)

    pipeline = [
        # Exclude orders still in transit (only delivered + returned)
        {"$match": {"order_status": {"$in": ["delivered", "returned"]}}},
        {"$unwind": "$items"},
        {"$group": {
            "_id":         "$items.category",
            "total_orders": {"$sum": 1},
            "returned":    {"$sum": {"$cond": [{"$eq": ["$order_status", "returned"]}, 1, 0]}},
            "revenue_lost": {"$sum": {
                "$cond": [{"$eq": ["$order_status", "returned"]}, "$items.line_total", 0]
            }},
        }},
        {"$addFields": {
            "return_rate_pct": {"$round": [
                {"$multiply": [{"$divide": ["$returned", "$total_orders"]}, 100]}, 1
            ]},
        }},
        {"$sort": {"return_rate_pct": DESCENDING}},
        {"$project": {
            "_id":             0,
            "category":        "$_id",
            "total_orders":    1,
            "returned":        1,
            "return_rate_pct": 1,
            "revenue_lost":    {"$round": ["$revenue_lost", 0]},
        }},
    ]

    results = list(db.orders.aggregate(pipeline))

    print(f"\n{'Category':<20} {'Total Orders':>13} {'Returned':>10} {'Return Rate':>12} {'Revenue Lost (₹)':>17}")
    print("-" * 76)
    for r in results:
        flag = " ⚠️" if r["return_rate_pct"] > 10 else ""
        print(f"{r['category']:<20} {r['total_orders']:>13,} {r['returned']:>10,} {r['return_rate_pct']:>11.1f}%{flag} {r['revenue_lost']:>17,.0f}")
    print(f"\n💡 Insight: Categories with >10% return rate (flagged ⚠️) need quality/description review.\n")
    return results


