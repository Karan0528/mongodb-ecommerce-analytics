# PIPELINE 3 — Top 10 products by revenue
# ═══════════════════════════════════════════════════════════════════════════════
def pipeline_3_top_products(db):
    print("=" * 60)
    print("PIPELINE 3 — Top 10 Products by Revenue")
    print("Business question: Which specific products are star performers?")
    print("=" * 60)

    pipeline = [
        {"$match": {"order_status": "delivered"}},
        {"$unwind": "$items"},
        {"$group": {
            "_id":      "$items.product_name",
            "category": {"$first": "$items.category"},
            "brand":    {"$first": "$items.brand"},
            "revenue":  {"$sum": "$items.line_total"},
            "qty_sold": {"$sum": "$items.quantity"},
        }},
        {"$sort": {"revenue": DESCENDING}},
        {"$limit": 10},
        {"$project": {
            "_id":      0,
            "product":  "$_id",
            "category": 1,
            "brand":    1,
            "revenue":  {"$round": ["$revenue", 0]},
            "qty_sold": 1,
        }},
    ]

    results = list(db.orders.aggregate(pipeline))

    print(f"\n{'Rank':<5} {'Product':<30} {'Category':<18} {'Revenue (₹)':>12} {'Qty':>6}")
    print("-" * 75)
    for i, r in enumerate(results, 1):
        print(f"{i:<5} {r['product']:<30} {r['category']:<18} {r['revenue']:>12,.0f} {r['qty_sold']:>6,}")
    print(f"\n💡 Insight: Cross-reference with inventory data to flag stockout risk on top SKUs.\n")
    return results


