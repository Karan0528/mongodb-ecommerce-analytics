def import_collections(db):
    for collection_name in ["products", "customers", "orders"]:
        col  = db[collection_name]
        path = DATA_DIR / f"{collection_name}.json"
        with open(path) as f:
            data = json.load(f)
        col.drop()                # fresh import each run
        col.insert_many(data)
        print(f"  ✅  Imported {len(data):,} docs → {collection_name}")

    # Create indexes for faster aggregation
    db.orders.create_index("order_date")
    db.orders.create_index("customer_id")
    db.orders.create_index("order_status")
    db.products.create_index("category")
    print("  ✅  Indexes created\n")


