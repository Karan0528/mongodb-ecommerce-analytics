# PIPELINE 2 — Monthly revenue trend (2022–2024)
# ═══════════════════════════════════════════════════════════════════════════════
def pipeline_2_monthly_trend(db):
    print("=" * 60)
    print("PIPELINE 2 — Monthly Revenue Trend")
    print("Business question: Is the business growing month-over-month?")
    print("=" * 60)

    pipeline = [
        {"$match": {"order_status": "delivered"}},

        # $dateFromString converts "2023-06-15T..." → proper date for $year/$month
        {"$addFields": {
            "order_date_parsed": {"$dateFromString": {"dateString": "$order_date"}}
        }},

        {"$group": {
            "_id": {
                "year":  {"$year":  "$order_date_parsed"},
                "month": {"$month": "$order_date_parsed"},
            },
            "revenue":     {"$sum": "$total_amount"},
            "order_count": {"$sum": 1},
        }},

        {"$sort": {"_id.year": 1, "_id.month": 1}},

        {"$project": {
            "_id":         0,
            "year":        "$_id.year",
            "month":       "$_id.month",
            "revenue":     {"$round": ["$revenue", 0]},
            "order_count": 1,
        }},
    ]

    results = list(db.orders.aggregate(pipeline))
    months  = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"]

    print(f"\n{'Period':<12} {'Revenue (₹)':>14} {'Orders':>8}")
    print("-" * 38)
    for r in results:
        period = f"{months[r['month']-1]} {r['year']}"
        print(f"{period:<12} {r['revenue']:>14,.0f} {r['order_count']:>8,}")
    print(f"\n💡 Insight: Look for seasonal spikes (Diwali = Oct/Nov). Export this for Tableau line chart.\n")
    return results


